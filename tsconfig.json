{
  "compilerOptions": {
    "experimentalDecorators": true,
    "target": "ES6",
    "module": "CommonJS",
    "rootDir": ".",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strictPropertyInitialization": false,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@surefy/*": [
        "./library/surefy/src/*"
      ],
      "@surefy/console/*": [
        "./src/*",
        "./src/app/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json",
    "library/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
