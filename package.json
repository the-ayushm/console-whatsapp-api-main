{
  "name": "console-api",
  "version": "1.0.0",
  "description": "Console API is a surefy meta services microservice for WhatsApp Business API management",
  "main": "index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/src/server.js",
    "start:worker": "cross-env WORKER_MODE=true node dist/src/workers/index.js",
    "dev": "nodemon -r dotenv/config -r tsconfig-paths/register src/server.ts",
    "worker": "cross-env WORKER_MODE=true nodemon -r dotenv/config -r tsconfig-paths/register src/workers/index.ts",
    "knex": "knex --knexfile library/surefy/src/config/knex.config.ts",
    "migrate:latest": "npm run knex -- migrate:latest",
    "migrate:rollback": "npm run knex -- migrate:rollback",
    "migrate:make": "npm run knex -- migrate:make",
    "seed": "npm run knex -- seed:run",
    "seed:make": "npm run knex -- seed:make",
    "prettier": "prettier --check 'src/**/*.{js,ts,tsx,json}'",
    "prettier:fix": "prettier --write 'src/**/*.{js,ts,tsx,json}'",
    "format": "npm run prettier:fix",
    "clean": "rimraf dist"
  },
  "keywords": [
    "Surefy",
    "Meta",
    "WhatsApp Business API",
    "Service"
  ],
  "author": "Surefy",
  "license": "ISC",
  "dependencies": {
    "@bull-board/api": "^6.15.0",
    "@bull-board/express": "^6.15.0",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "bull-board": "^1.7.2",
    "bullmq": "^5.66.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^14.0.0",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "libphonenumber-js": "^1.13.1",
    "lodash": "^4.17.21",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.6",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.0",
    "tsc-alias": "^1.8.16",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.7",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.2.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.1",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
